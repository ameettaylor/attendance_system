# ── Copy this file to .env and fill in the values ─────────────────────────────
# Never commit .env to version control.

# Database (Railway provides this automatically when you add a Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Twilio (from your Twilio console — twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Geofencing
GEOFENCE_RADIUS_METERS=200

# Scheduling (24-hour UTC times — Railway servers run UTC)
# Nairobi is UTC+3, so 16:30 UTC = 19:30 EAT, 17:00 UTC = 20:00 EAT
# Adjust to suit your working hours:
CHECKOUT_REMINDER_TIME=13:30
DAILY_SUMMARY_TIME=14:00

# Web dashboard session signing key
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_a_long_random_string
